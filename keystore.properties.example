# Copy this file to keystore.properties (git-ignored) and fill in your values.
# Generate a keystore with:
#   keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias dietreport
storeFile=release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=dietreport
keyPassword=YOUR_KEY_PASSWORD
